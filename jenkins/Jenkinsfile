pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerHubCred')   // Jenkins credential ID
        DOCKERHUB_USER        = "myserverd"
        IMAGE_TAG             = "${env.BUILD_NUMBER}"
        BACKEND_IMAGE         = "${DOCKERHUB_USER}/ai-chatbot-backend"
        FRONTEND_IMAGE        = "${DOCKERHUB_USER}/ai-chatbot-frontend"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                echo '📥 Pulling latest code from GitHub...'
                git branch: 'main', url: 'https://github.com/LohadeDarshan/ai-chatbot-devops.git'
            }
        }

        // ─── STAGE 2: SonarQube Scan ──────────────────────────────────
        stage('SonarQube Scan') {
            steps {
                script {
                    def scannerHome = tool 'sonar'
                    withSonarQubeEnv('sonar') {
                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=ai-chatbot-devops \
                        -Dsonar.projectName=ai-chatbot-devops \
                        -Dsonar.sources=backend,frontend \
                        -Dsonar.javascript.skip=true
                        """
                    }
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                sh "docker build -t ${BACKEND_IMAGE}:${IMAGE_TAG} -t ${BACKEND_IMAGE}:latest ./backend"
                sh "docker build -t ${FRONTEND_IMAGE}:${IMAGE_TAG} -t ${FRONTEND_IMAGE}:latest ./frontend"
            }
        }

        stage('Push Images to Docker Hub') {
            steps {
                withDockerRegistry(url: 'https://index.docker.io/v1/', credentialsId: 'dockerHubCred') {
                    sh """ 
                        docker push ${BACKEND_IMAGE}:${IMAGE_TAG}
                        docker push ${BACKEND_IMAGE}:latest
                        docker push ${FRONTEND_IMAGE}:${IMAGE_TAG}
                        docker push ${FRONTEND_IMAGE}:latest
                    """
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh '''
                        echo "Using kubeconfig: $KUBECONFIG"

                        kubectl get nodes

                        kubectl apply -f k8s/namespace.yaml
                        kubectl apply -f k8s/configmap.yaml
                        kubectl apply -f k8s/postgres-deployment.yaml
                        kubectl apply -f k8s/ollama-deployment.yaml
                        kubectl apply -f k8s/deployment.yaml
                        kubectl apply -f k8s/service.yaml
                        kubectl apply -f k8s/ingress.yaml
                        kubectl apply -f k8s/hpa.yaml

                        kubectl set image deployment/backend backend=${BACKEND_IMAGE}:${IMAGE_TAG} -n ai-chatbot
                        kubectl set image deployment/frontend frontend=${FRONTEND_IMAGE}:${IMAGE_TAG} -n ai-chatbot

                        kubectl rollout status deployment/backend -n ai-chatbot --timeout=120s
                        kubectl rollout status deployment/frontend -n ai-chatbot --timeout=120s
                    '''
                }
            }   
        }
    }

    post {
        success {
            echo "✅ Deployment successful — build #${IMAGE_TAG}"
        }
        failure {
            echo "❌ Pipeline failed — check logs for details"
        }
    }
}
